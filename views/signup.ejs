<%- include('partials/header', { title: 'Sign Up - WanderLux', page: 'signup' }) %>

<section class="auth-section">
    <div class="auth-image">
        <img src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1200" alt="Travel">
        <div class="auth-image-overlay">
            <div class="auth-quote">
                <p>"The world is a book, and those who do not travel read only one page"</p>
            </div>
        </div>
    </div>

    <div class="auth-form-side">
        <div class="auth-form-wrap">
            <a href="/" class="logo auth-logo">
                <i class="fas fa-compass"></i>
                <span>WanderLux</span>
            </a>
            <h2>Start your <em>journey</em></h2>
            <p class="auth-sub">Create a free account and unlock exclusive tour packages and offers.</p>

            <% if (error && error.length > 0) { %>
            <div class="flash flash-error"><i class="fas fa-exclamation-circle"></i> <%= error[0] %></div>
            <% } %>

            <form action="/auth/signup" method="POST" class="auth-form">
                <div class="form-group">
                    <label><i class="fas fa-user"></i> Full Name</label>
                    <input type="text" name="name" placeholder="Rahul Sharma" required>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-envelope"></i> Email Address</label>
                    <input type="email" name="email" placeholder="rahul@email.com" required>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-phone"></i> Phone Number</label>
                    <input type="tel" name="phone" placeholder="+91 98765 43210">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password</label>
                        <div class="input-password">
                            <input type="password" name="password" id="signupPass" placeholder="Min. 6 characters" required minlength="6">
                            <button type="button" class="toggle-pass" onclick="togglePass('signupPass')"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Confirm Password</label>
                        <div class="input-password">
                            <input type="password" name="confirm_password" id="confirmPass" placeholder="Repeat password" required>
                            <button type="button" class="toggle-pass" onclick="togglePass('confirmPass')"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-user-plus"></i> Create Account
                </button>
            </form>
            <p class="auth-switch">Already have an account? <a href="/auth/login">Sign in</a></p>
        </div>
    </div>
</section>

<script>
function togglePass(id) {
    const input = document.getElementById(id);
    const btn = input.nextElementSibling.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        btn.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        btn.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>
</body>
</html>
