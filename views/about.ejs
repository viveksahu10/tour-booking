<%- include('partials/header', { title: 'About Us - WanderLux Tours', page: 'about' }) %>

<!-- Page Hero -->
<section class="page-hero">
    <div class="page-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1539635278303-d4002c07eae3?w=1600')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
        <p class="section-eyebrow light">Our Story</p>
        <h1>About <em>WanderLux</em></h1>
        <p>Passionate travelers crafting unforgettable journeys since 2012</p>
    </div>
</section>

<!-- About Intro -->
<section class="about-intro">
    <div class="about-intro-grid">
        <div class="about-intro-images">
            <img src="https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=600" alt="Travel" class="img-main">
            <img src="https://images.unsplash.com/photo-1488085061387-422e29b40080?w=400" alt="Travel 2" class="img-secondary">
        </div>
        <div class="about-intro-text">
            <p class="section-eyebrow">Who We Are</p>
            <h2>Born from a <em>love of travel</em></h2>
            <p>WanderLux was founded in 2026 by a group of passionate travelers who believed that exploring India should be an extraordinary experience — not just a checklist of tourist spots.</p>
            <p>Over the years, we've grown into one of India's most trusted boutique travel companies, serving over 2,400 happy travelers across 48 destinations. But our heart remains the same: a deep love for this incredible country and a commitment to sharing it authentically.</p>
            <div class="about-stats">
                <div class="astat">
                    <span class="astat-num">50+</span>
                    <span class="astat-label">Travelers Served</span>
                </div>
                <div class="astat">
                    <span class="astat-num">15</span>
                    <span class="astat-label">Destinations</span>
                </div>
                <div class="astat">
                    <span class="astat-num">1+</span>
                    <span class="astat-label">Years Experience</span>
                </div>
                <div class="astat">
                    <span class="astat-num">4.5★</span>
                    <span class="astat-label">Average Rating</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Mission & Values -->
<section class="values-section">
    <div class="section-header">
        <p class="section-eyebrow">Our Promise</p>
        <h2 class="section-title">What We Stand <em>For</em></h2>
    </div>
    <div class="values-grid">
        <div class="value-card">
            <div class="value-icon"><i class="fas fa-heart"></i></div>
            <h3>Passion</h3>
            <p>Every tour is designed with genuine love for travel and a deep respect for each destination's culture and people.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="fas fa-leaf"></i></div>
            <h3>Sustainability</h3>
            <p>We work with local communities, minimize environmental impact, and ensure tourism benefits the places we visit.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="fas fa-lock"></i></div>
            <h3>Trust</h3>
            <p>Transparent pricing, no hidden fees, and honest communication. We build relationships, not just transactions.</p>
        </div>
        <div class="value-card">
            <div class="value-icon"><i class="fas fa-star"></i></div>
            <h3>Excellence</h3>
            <p>From guides to accommodations, we obsess over every detail so you can focus on the magic of travel.</p>
        </div>
    </div>
</section>

