<%- include('partials/header', { title: 'Login - WanderLux', page: 'login' }) %>

<section class="auth-section">
    <div class="auth-image">
        <img src="https://images.unsplash.com/photo-1570168007204-dfb528c6958f?w=1200" alt="Travel">
        <div class="auth-image-overlay">
            <div class="auth-quote">
                <p>"Travel is the only thing you buy that makes you richer"</p>
            </div>
        </div>
    </div>

    <div class="auth-form-side">
        <div class="auth-form-wrap">
            <a href="/" class="logo auth-logo">
                <i class="fas fa-compass"></i>
                <span>WanderLux</span>
            </a>
            <h2>Welcome <em>back</em></h2>
            <p class="auth-sub">Sign in to manage your bookings and explore new adventures.</p>

            <% if (error && error.length > 0) { %>
            <div class="flash flash-error"><i class="fas fa-exclamation-circle"></i> <%= error[0] %></div>
            <% } %>
            <% if (success && success.length > 0) { %>
            <div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= success[0] %></div>
            <% } %>

            <form action="/auth/login" method="POST" class="auth-form">
                <div class="form-group">
                    <label><i class="fas fa-envelope"></i> Email Address</label>
                    <input type="email" name="email" placeholder="your@email.com" required autofocus>
                </div>
                <div class="form-group">
                    <label><i class="fas fa-lock"></i> Password</label>
                    <div class="input-password">
                        <input type="password" name="password" id="loginPass" placeholder="Your password" required>
                        <button type="button" class="toggle-pass" onclick="togglePass('loginPass')"><i class="fas fa-eye"></i></button>
                    </div>
                </div>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </button>
            </form>
            <p class="auth-switch">Don't have an account? <a href="/auth/signup">Create one free</a></p>
        </div>
    </div>
</section>

<script>
function togglePass(id) {
    const input = document.getElementById(id);
    const btn = input.nextElementSibling.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        btn.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
        input.type = 'password';
        btn.classList.replace('fa-eye-slash', 'fa-eye');
    }
}
</script>
</body>
</html>
