<%- include('partials/header', { title: 'Contact Us - WanderLux', page: 'contact' }) %>

<!-- Page Hero -->
<section class="page-hero short-hero">
    <div class="page-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1423347834838-5162bb452702?w=1600')"></div>
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
        <p class="section-eyebrow light">Get in Touch</p>
        <h1>Contact <em>Us</em></h1>
        <p>We'd love to hear from you and help plan your dream trip</p>
    </div>
</section>

<!-- Flash Messages -->
<% if (messages && messages.success && messages.success.length > 0) { %>
<div class="flash flash-success"><i class="fas fa-check-circle"></i> <%= messages.success[0] %></div>
<% } %>
<% if (messages && messages.error && messages.error.length > 0) { %>
<div class="flash flash-error"><i class="fas fa-exclamation-circle"></i> <%= messages.error[0] %></div>
<% } %>

<section class="contact-section">
    <div class="contact-grid">
        <!-- Contact Info -->
        <div class="contact-info">
            <h2>Let's <em>Talk Travel</em></h2>
            <p>Whether you have questions about a tour, need a custom itinerary, or just want to chat about your dream destination — we're here for you.</p>
            <div class="cinfo-items">
                <div class="cinfo-item">
                    <div class="cinfo-icon"><i class="fas fa-map-marker-alt"></i></div>
                    <div>
                        <h4>Visit Us</h4>
                        <p>99 Ashoka Vihara, Bhopal <br>Madhya Pradesh 462023</p>
                    </div>
                </div>
                <div class="cinfo-item">
                    <div class="cinfo-icon"><i class="fas fa-phone"></i></div>
                    <div>
                        <h4>Call Us</h4>
                        <p>+91 9770141815</p>
                        <p>Mon–Sat, 9am–7pm IST</p>
                    </div>
                </div>
                <div class="cinfo-item">
                    <div class="cinfo-icon"><i class="fas fa-envelope"></i></div>
                    <div>
                        <h4>Email Us</h4>
                        <p>sahuv9224@gmail.com</p>
                        <p>We reply within 24 hours</p>
                    </div>
                </div>
            </div>
            <div class="contact-social">
                <p>Follow our adventures:</p>
                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-youtube"></i></a>
                </div>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-wrap">
            <form action="/contact" method="POST" class="contact-form">
                <div class="form-row">
                    <div class="form-group">
                        <label>Your Name *</label>
                        <input type="text" name="name" placeholder="Rahul Sharma" required>
                    </div>
                    <div class="form-group">
                        <label>Email Address *</label>
                        <input type="email" name="email" placeholder="rahul@email.com" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Subject</label>
                    <input type="text" name="subject" placeholder="Tour inquiry / Custom package / General question">
                </div>
                <div class="form-group">
                    <label>Message *</label>
                    <textarea name="message" rows="6" placeholder="Tell us about your dream trip — destinations, travel dates, group size, preferences..." required></textarea>
                </div>
                <button type="submit" class="btn-submit">
                    <i class="fas fa-paper-plane"></i> Send Message
                </button>
            </form>
        </div>
    </div>
</section>

<!-- Map placeholder -->
<section class="map-section">
    <div class="map-placeholder">
        <i class="fas fa-map-marked-alt"></i>
        <p>99 Ashoka Vihara, Bhopal, Madhya Pradesh — India's heart</p>
    </div>
</section>

<%- include('partials/footer') %>
