<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'WanderLux Tours' %></title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>

<!-- Navigation -->
<nav class="navbar" id="navbar">
    <div class="nav-container">

        <a href="/" class="logo">
            <i class="fas fa-compass"></i>
            <span>WanderLux</span>
        </a>

        <ul class="nav-links" id="navLinks">
            <li>
                <a href="/" class="<%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>">
                    Home
                </a>
            </li>

            <li>
                <a href="/about" class="<%= typeof page !== 'undefined' && page === 'about' ? 'active' : '' %>">
                    About
                </a>
            </li>

            <li>
                <a href="/booking" class="<%= typeof page !== 'undefined' && page === 'booking' ? 'active' : '' %>">
                    Booking
                </a>
            </li>

            <li>
                <a href="/contact" class="<%= typeof page !== 'undefined' && page === 'contact' ? 'active' : '' %>">
                    Contact
                </a>
            </li>
        </ul>

        <div class="nav-auth">

            <% if (typeof user !== 'undefined' && user) { %>

                <span class="nav-user">
                    <i class="fas fa-user-circle"></i>
                    <%= user.name ? user.name.split(' ')[0] : 'User' %>
                </span>

                <a href="/auth/logout" class="btn-nav-outline">
                    Logout
                </a>

            <% } else { %>

                <a href="/auth/login" class="btn-nav-outline">
                    Login
                </a>

                <a href="/auth/signup" class="btn-nav-solid">
                    Sign Up
                </a>

            <% } %>

        </div>

        <button class="hamburger" id="hamburger" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>

    </div>
</nav>